# Philip Builds Studio — AI backend environment (EXAMPLE ONLY)
# Copy to .env for local dev, or set these in your host's dashboard
# (Vercel/Netlify project settings). NEVER commit a real .env file.
# The static GitHub Pages site does NOT read these — only the optional
# serverless function in api/chat.js does.

# Required to enable real model-powered replies (use ONE of these):
AI_PROVIDER_API_KEY=
# OPENAI_API_KEY=

# Optional — defaults shown. Any OpenAI-compatible Chat Completions API works.
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
